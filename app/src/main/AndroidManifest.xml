<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <permission
        android:name="com.dov.calculator.READ_PERMISSION"
        android:protectionLevel="normal"
        android:label="Read Calculator Data" />

    <application
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Calculator"
        tools:targetApi="31">
        <activity
            android:name=".preferences.SettingsActivity"
            android:exported="false"
            android:parentActivityName=".RichFormActivity"/>
        <activity
            android:name=".RichFormActivity"
            android:exported="true" >
        </activity>
        <activity
            android:name=".history.HistoryActivity"
            android:parentActivityName=".Calculator"
            android:theme="@style/Theme.ActionBar"
            android:exported="false" />
        <activity
            android:name=".Calculator"
            android:exported="false"/>
        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <provider
            android:name=".AppContentProvider"
            android:authorities="com.dov.calculator.provider"
            android:exported="true"
            android:readPermission="com.dov.calculator.READ_PERMISSION" />

    </application>

</manifest>